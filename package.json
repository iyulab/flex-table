{
  "name": "@iyulab/flex-table",
  "version": "0.16.0",
  "description": "A minimalist, input-centric data grid web component",
  "type": "module",
  "main": "./dist/flex-table.js",
  "module": "./dist/flex-table.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/flex-table.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./odata": {
      "types": "./dist/odata/index.d.ts",
      "import": "./dist/odata/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve demo",
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:demo": "vite build --config vite.config.demo.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "web-component",
    "data-grid",
    "table",
    "lit",
    "spreadsheet"
  ],
  "license": "MIT",
  "author": "iyulab",
  "homepage": "https://github.com/iyulab/flex-table#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/iyulab/flex-table.git"
  },
  "bugs": {
    "url": "https://github.com/iyulab/flex-table/issues"
  },
  "dependencies": {
    "lit": "^3.3.3",
    "odata-query": "^8.0.7"
  },
  "peerDependencies": {
    "@lit/react": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@lit/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lit/react": "^1.0.8",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.1.0",
    "eslint-plugin-lit": "^2.3.1",
    "jsdom": "^29.1.1",
    "loupe": "^3.2.1",
    "react": "^19.2.6",
    "strip-literal": "^3.1.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
